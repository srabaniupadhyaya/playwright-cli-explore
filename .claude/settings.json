{
  "permissions": {
    "allow": [
      "Bash(git diff*)",
      "Bash(git status)",
      "Bash(npm run *)"
    ],
    "deny": [
      "Read(./.env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Edit(.git/**)",
      "Write(.git/**)"
    ],
    "ask": [
      "Edit(playwright.config.ts)",
      "Write(playwright.config.ts)",
      "Read(./config/config.json)",
      "Edit(./config/config.json)",
      "Write(./config/config.json)",
      "Bash(git push*)",
      "Bash(git branch -D *)"
    ]
  }
}
